generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Config {
  id           String   @id @default("app-data")
  activePageId String?
  scanInterval String?
  updatedAt    DateTime @updatedAt
}

model Page {
  id      String   @id @default(cuid())
  name    String
  order   Int      @default(0)
  userId  String?
  user    User?    @relation(fields: [userId], references: [id])
  devices Device[]
}

model Device {
  id          String   @id @default(cuid())
  name        String
  host        String
  ports       String
  order       Int      @default(0)
  ipUpdatedAt DateTime?
  
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pages     Page[]
}
